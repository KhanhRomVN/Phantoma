{
  "name": "Aurora",
  "monaco": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "foreground": "5c7a6e", "token": "comment" },
      { "foreground": "6ee7b7", "token": "constant" },
      { "foreground": "34d399", "token": "entity" },
      { "foreground": "34d399", "token": "keyword" },
      { "foreground": "34d399", "token": "storage" },
      { "foreground": "a3e635", "token": "string" },
      { "foreground": "a3e635", "token": "meta.verbatim" },
      { "foreground": "6ee7b7", "token": "support" },
      { "foreground": "fb7185", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "ecfdf5", "background": "e11d48", "token": "invalid.illegal" },
      { "foreground": "34d399", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "34d399", "token": "string constant.other.placeholder" },
      { "foreground": "88b8a0", "token": "meta.tag" },
      { "foreground": "88b8a0", "token": "meta.tag entity" },
      { "foreground": "d1fae5", "token": "entity.name.section" },
      { "foreground": "a7f3d0", "token": "variable" },
      { "foreground": "a7f3d0", "token": "variable.parameter" },
      { "foreground": "a7f3d0", "token": "variable.name" },
      { "foreground": "fde047", "token": "entity.name.function" },
      { "foreground": "fde047", "token": "meta.function-call" },
      { "foreground": "5eead4", "token": "entity.name.type" },
      { "foreground": "5eead4", "token": "entity.name.class" },
      { "foreground": "5eead4", "token": "support.type" },
      { "foreground": "5eead4", "token": "support.class" },
      { "foreground": "fca5a5", "token": "string.escape" },
      { "foreground": "a7f3d0", "token": "identifier" },
      { "foreground": "bef264", "token": "number" },
      { "foreground": "fca5a5", "token": "character" },
      { "foreground": "c084fc", "token": "meta.preprocessor" },
      { "foreground": "c084fc", "token": "keyword.control" },
      { "foreground": "2dd4bf", "token": "keyword.operator" },
      { "foreground": "34d399", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#d1fae5",
      "editor.background": "#0d1e1a",
      "editor.selectionBackground": "#1a3a30",
      "editor.lineHighlightBackground": "#122620",
      "editorCursor.foreground": "#34d399",
      "editorWhitespace.foreground": "#2d5a46"
    }
  },
  "tailwind": {
