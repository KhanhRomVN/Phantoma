{
  "name": "Nocturne",
  "monaco": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "foreground": "6b7280", "token": "comment" },
      { "foreground": "60a5fa", "token": "constant" },
      { "foreground": "818cf8", "token": "entity" },
      { "foreground": "818cf8", "token": "keyword" },
      { "foreground": "818cf8", "token": "storage" },
      { "foreground": "34d399", "token": "string" },
      { "foreground": "34d399", "token": "meta.verbatim" },
      { "foreground": "60a5fa", "token": "support" },
      { "foreground": "f87171", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "f9fafb", "background": "dc2626", "token": "invalid.illegal" },
      { "foreground": "818cf8", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "818cf8", "token": "string constant.other.placeholder" },
      { "foreground": "9ca3af", "token": "meta.tag" },
      { "foreground": "9ca3af", "token": "meta.tag entity" },
      { "foreground": "e5e7eb", "token": "entity.name.section" },
      { "foreground": "93c5fd", "token": "variable" },
      { "foreground": "93c5fd", "token": "variable.parameter" },
      { "foreground": "93c5fd", "token": "variable.name" },
      { "foreground": "fbbf24", "token": "entity.name.function" },
      { "foreground": "fbbf24", "token": "meta.function-call" },
      { "foreground": "6ee7b7", "token": "entity.name.type" },
      { "foreground": "6ee7b7", "token": "entity.name.class" },
      { "foreground": "6ee7b7", "token": "support.type" },
      { "foreground": "6ee7b7", "token": "support.class" },
      { "foreground": "fca5a5", "token": "string.escape" },
      { "foreground": "93c5fd", "token": "identifier" },
      { "foreground": "a5f3d0", "token": "number" },
      { "foreground": "fca5a5", "token": "character" },
      { "foreground": "c084fc", "token": "meta.preprocessor" },
      { "foreground": "c084fc", "token": "keyword.control" },
      { "foreground": "38bdf8", "token": "keyword.operator" },
      { "foreground": "818cf8", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#e5e7eb",
      "editor.background": "#0f111a",
      "editor.selectionBackground": "#1e2533",
      "editor.lineHighlightBackground": "#161b26",
      "editorCursor.foreground": "#818cf8",
      "editorWhitespace.foreground": "#374151"
    }
  },
