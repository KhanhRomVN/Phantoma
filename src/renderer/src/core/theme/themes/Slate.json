{
  "name": "Slate",
  "monaco": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "foreground": "64748b", "token": "comment" },
      { "foreground": "67e8f9", "token": "constant" },
      { "foreground": "38bdf8", "token": "entity" },
      { "foreground": "38bdf8", "token": "keyword" },
      { "foreground": "38bdf8", "token": "storage" },
      { "foreground": "34d399", "token": "string" },
      { "foreground": "34d399", "token": "meta.verbatim" },
      { "foreground": "67e8f9", "token": "support" },
      { "foreground": "f87171", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "f8fafc", "background": "dc2626", "token": "invalid.illegal" },
      { "foreground": "38bdf8", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "38bdf8", "token": "string constant.other.placeholder" },
      { "foreground": "94a3b8", "token": "meta.tag" },
      { "foreground": "94a3b8", "token": "meta.tag entity" },
      { "foreground": "e2e8f0", "token": "entity.name.section" },
      { "foreground": "7dd3fc", "token": "variable" },
      { "foreground": "7dd3fc", "token": "variable.parameter" },
      { "foreground": "7dd3fc", "token": "variable.name" },
      { "foreground": "facc15", "token": "entity.name.function" },
      { "foreground": "facc15", "token": "meta.function-call" },
      { "foreground": "5eead4", "token": "entity.name.type" },
      { "foreground": "5eead4", "token": "entity.name.class" },
      { "foreground": "5eead4", "token": "support.type" },
      { "foreground": "5eead4", "token": "support.class" },
      { "foreground": "fda4af", "token": "string.escape" },
      { "foreground": "7dd3fc", "token": "identifier" },
      { "foreground": "99f6e4", "token": "number" },
      { "foreground": "fda4af", "token": "character" },
      { "foreground": "c084fc", "token": "meta.preprocessor" },
      { "foreground": "c084fc", "token": "keyword.control" },
      { "foreground": "22d3ee", "token": "keyword.operator" },
      { "foreground": "38bdf8", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#e2e8f0",
      "editor.background": "#0f1119",
      "editor.selectionBackground": "#1e2433",
      "editor.lineHighlightBackground": "#171b26",
      "editorCursor.foreground": "#22d3ee",
      "editorWhitespace.foreground": "#334155"
    }
  },
  "tailwind": {
    "primary": "34 211 238",
    "background": "15 17 25",
    "textPrimary": "226 232 240",
    "textSecondary": "148 163 184",
    "border": "30 41 59",
