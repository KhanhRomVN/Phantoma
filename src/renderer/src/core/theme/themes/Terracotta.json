{
  "name": "Terracotta",
  "monaco": {
    "base": "vs",
    "inherit": true,
    "rules": [
      { "foreground": "a09080", "token": "comment" },
      { "foreground": "c4715a", "token": "constant" },
      { "foreground": "d4845f", "token": "entity" },
      { "foreground": "b56242", "token": "keyword" },
      { "foreground": "b56242", "token": "storage" },
      { "foreground": "5c8a3c", "token": "string" },
      { "foreground": "5c8a3c", "token": "meta.verbatim" },
      { "foreground": "c4715a", "token": "support" },
      { "foreground": "cf4444", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "fefaf6", "background": "dc2626", "token": "invalid.illegal" },
      { "foreground": "d4845f", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "d4845f", "token": "string constant.other.placeholder" },
      { "foreground": "5c4a3c", "token": "meta.tag" },
      { "foreground": "5c4a3c", "token": "meta.tag entity" },
      { "foreground": "2d1f18", "token": "entity.name.section" },
      { "foreground": "4a3026", "token": "variable" },
      { "foreground": "3d251c", "token": "variable.parameter" },
      { "foreground": "4a3026", "token": "variable.name" },
      { "foreground": "8b6c1e", "token": "entity.name.function" },
      { "foreground": "8b6c1e", "token": "meta.function-call" },
      { "foreground": "4d7c3b", "token": "entity.name.type" },
      { "foreground": "4d7c3b", "token": "entity.name.class" },
      { "foreground": "4d7c3b", "token": "support.type" },
      { "foreground": "4d7c3b", "token": "support.class" },
      { "foreground": "b8472a", "token": "string.escape" },
      { "foreground": "4a3026", "token": "identifier" },
      { "foreground": "3d6b2e", "token": "number" },
      { "foreground": "b8472a", "token": "character" },
      { "foreground": "8b5e8a", "token": "meta.preprocessor" },
      { "foreground": "8b5e8a", "token": "keyword.control" },
      { "foreground": "b56242", "token": "keyword.operator" },
      { "foreground": "c4715a", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#2d1f18",
      "editor.background": "#fefaf6",
      "editor.selectionBackground": "#f5e8dc",
      "editor.lineHighlightBackground": "#fcf6f0",
      "editorCursor.foreground": "#c4715a",
      "editorWhitespace.foreground": "#d9cbb8"
    }
  },
  "tailwind": {
    "primary": "196 113 90",
    "background": "254 250 246",
    "textPrimary": "45 31 24",
    "textSecondary": "138 110 90",
    "border": "232 218 202",
    "borderHover": "210 188 165",
    "borderFocus": "210 188 165",
    "cardBackground": "255 255 255",
    "inputBackground": "255 255 255",
    "inputBorderDefault": "232 218 202",
    "inputBorderHover": "210 188 165",
    "inputBorderFocus": "196 113 90",
    "dialogBackground": "255 255 255",
    "dropdownBackground": "255 255 255",
    "dropdownItemHover": "252 246 240",
    "dropdownBorder": "232 218 202",
    "dropdownBorderHover": "210 188 165",
    "sidebarBackground": "251 245 238",
    "sidebarItemHover": "245 235 224",
    "sidebarItemFocus": "237 223 208",
    "buttonBg": "196 113 90",
    "buttonBgHover": "180 92 68",
    "buttonText": "255 255 255",
    "buttonBorder": "180 92 68",
    "buttonBorderHover": "156 74 52",
    "buttonSecondBg": "240 228 216",
    "buttonSecondBgHover": "226 208 190",
    "bookmarkItemBg": "245 235 224",
    "bookmarkItemText": "45 31 24",
    "drawerBackground": "255 255 255",
    "clockGradientFrom": "196 113 90",
    "clockGradientTo": "220 158 100",
    "cardShadow": "0 1px 3px 0 rgb(0 0 0 / 0.06)",
    "dialogShadow": "0 25px 50px -12px rgb(0 0 0 / 0.2)",
    "dropdownShadow": "0 10px 15px -3px rgb(0 0 0 / 0.08)",
    "tableHeaderBg": "251 245 238",
    "tableHoverHeaderBg": "245 235 224",
    "tableBodyBg": "255 255 255",
    "tableHoverItemBodyBg": "252 246 240",
    "tableFocusItemBodyBg": "245 235 224",
    "tableFooterBg": "251 245 238",
    "tableHoverFooterBg": "245 235 224",
    "tableBorder": "232 218 202",
    "tabBackground": "255 255 255",
    "tabBorder": "232 218 202",
    "tabHoverBorder": "210 188 165",
    "tabItemBackground": "transparent",
    "tabItemHoverBg": "252 246 240",
    "tabItemFocusBg": "245 235 224",
    "tabItemBorder": "transparent",
    "tabItemHoverBorder": "210 188 165",
    "tabItemFocusBorder": "196 113 90",
    "divider": "235 223 210"
  }
}