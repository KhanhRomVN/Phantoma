{
  "name": "Verdant",
  "monaco": {
    "base": "vs",
    "inherit": true,
    "rules": [
      { "foreground": "6b7c6e", "token": "comment" },
      { "foreground": "2d6a4f", "token": "constant" },
      { "foreground": "40916c", "token": "entity" },
      { "foreground": "2d6a4f", "token": "keyword" },
      { "foreground": "2d6a4f", "token": "storage" },
      { "foreground": "1b7052", "token": "string" },
      { "foreground": "1b7052", "token": "meta.verbatim" },
      { "foreground": "40916c", "token": "support" },
      { "foreground": "c73e3e", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "1a241c", "background": "e74c3c", "token": "invalid.illegal" },
      { "foreground": "40916c", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "40916c", "token": "string constant.other.placeholder" },
      { "foreground": "3a4d3c", "token": "meta.tag" },
      { "foreground": "3a4d3c", "token": "meta.tag entity" },
      { "foreground": "1a241c", "token": "entity.name.section" },
      { "foreground": "2d4731", "token": "variable" },
      { "foreground": "1e3a22", "token": "variable.parameter" },
      { "foreground": "2d4731", "token": "variable.name" },
      { "foreground": "8b6914", "token": "entity.name.function" },
      { "foreground": "8b6914", "token": "meta.function-call" },
      { "foreground": "2f6b4a", "token": "entity.name.type" },
      { "foreground": "2f6b4a", "token": "entity.name.class" },
      { "foreground": "2f6b4a", "token": "support.type" },
      { "foreground": "2f6b4a", "token": "support.class" },
      { "foreground": "b5452b", "token": "string.escape" },
      { "foreground": "2d4731", "token": "identifier" },
      { "foreground": "1b7052", "token": "number" },
      { "foreground": "b5452b", "token": "character" },
      { "foreground": "7b4f8a", "token": "meta.preprocessor" },
      { "foreground": "7b4f8a", "token": "keyword.control" },
      { "foreground": "2d6a4f", "token": "keyword.operator" },
      { "foreground": "40916c", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#1a241c",
      "editor.background": "#fafbf7",
      "editor.selectionBackground": "#e6efe4",
      "editor.lineHighlightBackground": "#f3f6f0",
      "editorCursor.foreground": "#40916c",
      "editorWhitespace.foreground": "#c5d1c3"
    }
  },
  "tailwind": {
    "primary": "64 145 108",
    "background": "250 251 247",
    "textPrimary": "26 36 28",
    "textSecondary": "107 124 110",
    "border": "213 224 210",
    "borderHover": "177 199 172",
    "borderFocus": "177 199 172",
    "cardBackground": "255 255 255",
    "inputBackground": "255 255 255",
    "inputBorderDefault": "213 224 210",
    "inputBorderHover": "177 199 172",
    "inputBorderFocus": "64 145 108",
    "dialogBackground": "255 255 255",
    "dropdownBackground": "255 255 255",
    "dropdownItemHover": "243 246 240",
    "dropdownBorder": "213 224 210",
    "dropdownBorderHover": "177 199 172",
    "sidebarBackground": "244 247 241",
    "sidebarItemHover": "237 242 233",
    "sidebarItemFocus": "224 232 219",
    "buttonBg": "64 145 108",
    "buttonBgHover": "45 106 79",
    "buttonText": "255 255 255",
