    "buttonBorderHover": "33 80 59",
    "buttonSecondBg": "232 237 228",
    "buttonSecondBgHover": "209 219 203",
    "bookmarkItemBg": "237 242 233",
    "bookmarkItemText": "26 36 28",
    "drawerBackground": "255 255 255",
