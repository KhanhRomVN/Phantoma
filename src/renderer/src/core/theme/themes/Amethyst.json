{
  "name": "Amethyst",
  "monaco": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "foreground": "7c6f8a", "token": "comment" },
      { "foreground": "c4b5fd", "token": "constant" },
      { "foreground": "a78bfa", "token": "entity" },
      { "foreground": "a78bfa", "token": "keyword" },
      { "foreground": "a78bfa", "token": "storage" },
      { "foreground": "6ee7b7", "token": "string" },
      { "foreground": "6ee7b7", "token": "meta.verbatim" },
      { "foreground": "c4b5fd", "token": "support" },
      { "foreground": "fda4af", "fontStyle": "italic", "token": "invalid.deprecated" },
      { "foreground": "fdf2f8", "background": "e11d48", "token": "invalid.illegal" },
      { "foreground": "a78bfa", "fontStyle": "italic", "token": "entity.other.inherited-class" },
      { "foreground": "a78bfa", "token": "string constant.other.placeholder" },
      { "foreground": "b0a0c8", "token": "meta.tag" },
      { "foreground": "b0a0c8", "token": "meta.tag entity" },
      { "foreground": "ede4f5", "token": "entity.name.section" },
      { "foreground": "ddd6fe", "token": "variable" },
      { "foreground": "ddd6fe", "token": "variable.parameter" },
      { "foreground": "ddd6fe", "token": "variable.name" },
      { "foreground": "fcd34d", "token": "entity.name.function" },
      { "foreground": "fcd34d", "token": "meta.function-call" },
      { "foreground": "a5f3d0", "token": "entity.name.type" },
      { "foreground": "a5f3d0", "token": "entity.name.class" },
      { "foreground": "a5f3d0", "token": "support.type" },
      { "foreground": "a5f3d0", "token": "support.class" },
      { "foreground": "fbc4cc", "token": "string.escape" },
      { "foreground": "ddd6fe", "token": "identifier" },
      { "foreground": "b7f3d4", "token": "number" },
      { "foreground": "fbc4cc", "token": "character" },
      { "foreground": "f0abfc", "token": "meta.preprocessor" },
      { "foreground": "f0abfc", "token": "keyword.control" },
      { "foreground": "67e8f9", "token": "keyword.operator" },
      { "foreground": "a78bfa", "token": "storage.type" }
    ],
    "colors": {
      "editor.foreground": "#ede4f5",
      "editor.background": "#1a1124",
      "editor.selectionBackground": "#2d1e3d",
      "editor.lineHighlightBackground": "#231830",
      "editorCursor.foreground": "#c4b5fd",
      "editorWhitespace.foreground": "#4a3d5c"
    }
  },
